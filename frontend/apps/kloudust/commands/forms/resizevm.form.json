"form": {
    "description": "{{{i18n.VMResizeDescription}}}",

    "load_javascript": [
        "const form = arguments[0];",
        "const DEFAULT_DISK = '__org_kloudust_default_disk_name';",
        "const vmData = APP_CONSTANTS.ENV._vms_form_data || {};",
        "const disks = Array.isArray(vmData.disks) ? vmData.disks : [];",
        "const isAttached = d => d.attached !== false;",
        "const allFields = [...(form.required_fields||[]), ...(form.optional_fields||[])];",
        "const fieldByID = id => allFields.find(f => f.id === id);",
        "const resizeField = fieldByID('disk_resize_target');",
        "if (resizeField) resizeField.options = disks.filter(isAttached).map(d => d.diskname === DEFAULT_DISK ? {value:'', label:'Primary (boot) disk'} : {value:d.diskname, label:d.diskname});",
        "const removeField = fieldByID('disk_remove_target');",
        "if (removeField) { const additional = disks.filter(d => d.diskname !== DEFAULT_DISK && isAttached(d)); removeField.options = additional.length ? additional.map(d => ({value:d.diskname, label:d.diskname})) : [{value:'', label:'No attached disks to remove'}]; }",
        "const attachField = fieldByID('disk_attach_target');",
        "if (attachField) { const detached = disks.filter(d => d.diskname !== DEFAULT_DISK && !isAttached(d)); attachField.options = detached.length ? detached.map(d => ({value:d.diskname, label:d.diskname})) : [{value:'', label:'No detached disks to attach'}]; }",
        "return form;"
    ],

    "rendered_javascript": [
        "const form = arguments[0], shadowRoot = form._form_shadowroot;",
        "if (!shadowRoot) return true;",
        "const opSelect = shadowRoot.querySelector('#disk_operation');",
        "const fieldGroups = {none: [], add: ['disk_add_name','disk_add_size'], resize: ['disk_resize_target','disk_resize_size'], detach: ['disk_remove_target'], delete: ['disk_remove_target'], attach: ['disk_attach_target']};",
        "const mandatoryInputs = ['disk_add_name','disk_add_size','disk_resize_size'];",
        "const allDiskFieldIDs = ['disk_add_name','disk_add_size','disk_resize_target','disk_resize_size','disk_remove_target','disk_attach_target'];",
        "const setVisible = (id, visible) => { const el = shadowRoot.querySelector('#'+id); if (!el) return; const label = shadowRoot.querySelector(`label[for='${id}']`); el.style.display = visible ? '' : 'none'; if (label) label.style.display = visible ? '' : 'none'; const mandatory = visible && mandatoryInputs.includes(id); el.required = mandatory; el.dataset.optional = mandatory ? 'false' : 'true'; if (!visible && el.tagName !== 'SELECT') el.value = ''; };",
        "const refresh = () => { const op = opSelect ? opSelect.value : 'none'; for (const id of allDiskFieldIDs) setVisible(id, false); for (const id of (fieldGroups[op]||[])) setVisible(id, true); };",
        "if (opSelect) opSelect.addEventListener('change', refresh);",
        "refresh();",
        "return true;"
    ],

    "submit_javascript": [
        "const values = arguments[0];",
        "const op = values.disk_operation || 'none';",
        "values.disk = ''; values.disk_name = ''; values.resize_disk_inplace = 'false'; values.remove_disk = 'false'; values.attach_disk = 'false';",
        "if (op === 'add') { values.disk = values.disk_add_size || ''; values.disk_name = values.disk_add_name || ''; }",
        "else if (op === 'resize') { values.disk = values.disk_resize_size || ''; values.disk_name = values.disk_resize_target || ''; values.resize_disk_inplace = 'true'; }",
        "else if (op === 'detach') { values.disk_name = values.disk_remove_target || ''; values.remove_disk = 'true'; }",
        "else if (op === 'delete') { values.disk_name = values.disk_remove_target || ''; values.remove_disk = 'delete'; }",
        "else if (op === 'attach') { values.disk_name = values.disk_attach_target || ''; values.attach_disk = 'true'; }",
        "return true;"
    ],

    "required_label": "{{{i18n.Required}}}",
    "required_fields": [
    {"id": "vm_name", "type": "text", "placeholder": "{{{i18n.VMName}}}", "required": true, 
        "pattern":"\\s*\\w+\\s*", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}", 
        "value":"{{{APP_CONSTANTS.ENV._vms_form_data.name_raw}}}", 
        "readonly":"{{#APP_CONSTANTS.ENV._vms_form_data.name_raw}}true{{/APP_CONSTANTS.ENV._vms_form_data.name_raw}}"},
    {"id": "cores", "type": "number", "placeholder": "{{{i18n.VMCores}}}", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "memory", "type": "number", "placeholder": "{{{i18n.VMMemory}}}", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "restart", "multioption": true, "type": "select", "label": "{{{i18n.VMResizeRestart}}}",
        "options":[{"value":"false", "label":"{{{i18n.VMNo}}}"}, {"value":"true", "label":"{{{i18n.VMYes}}}"}]},
    {"id": "disk_operation", "multioption": true, "type": "select", "label": "{{{i18n.VMDiskOperation}}}",
        "options":[{"value":"none", "label":"{{{i18n.VMDiskOpNone}}}"}, {"value":"add", "label":"{{{i18n.VMDiskOpAdd}}}"}, {"value":"resize", "label":"{{{i18n.VMDiskOpResize}}}"}, {"value":"detach", "label":"{{{i18n.VMDiskOpDetach}}}"}, {"value":"delete", "label":"{{{i18n.VMDiskOpDelete}}}"}, {"value":"attach", "label":"{{{i18n.VMDiskOpAttach}}}"}]},
    {"id": "disk_add_name", "type": "text", "placeholder": "{{{i18n.VMNewDiskName}}}", "pattern":"\\s*\\w+\\s*", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "disk_add_size", "type": "number", "min":"1", "placeholder": "{{{i18n.VMNewDiskSize}}}", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "disk_resize_target", "multioption": true, "type": "select", "label": "{{{i18n.VMResizeTarget}}}", "options":[]},
    {"id": "disk_resize_size", "type": "number", "min":"1", "placeholder": "{{{i18n.VMResizeNewSize}}}", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "disk_remove_target", "multioption": true, "type": "select", "label": "{{{i18n.VMRemoveTarget}}}", "options":[]},
    {"id": "disk_attach_target", "multioption": true, "type": "select", "label": "{{{i18n.VMAttachTarget}}}", "options":[]}
    ],

    "submitlabel": "{{{i18n.ResizeVMSubmitLabel}}}"
}

}