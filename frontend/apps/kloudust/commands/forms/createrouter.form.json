{
"id": "createrouter",
"command": "createRouter",
"type": "kloudust_cmdline",
"kloudust_cmdline_params": ["router_name", "router_description", "router_settings","cores", "memory", "disk", "creation_image_name", "cloudinit_data"],

"title": "{{{i18n.RouterTitle}}}",

"i18n": {
    "en": {
        "RouterTitle": "Create Router",
        "RouterDescription": "Create a Router.",
        "RouterDescriptionField": "Description",
        "RouterName": "Name",
        "FieldValidationErrorGeneric": "Validation error",
        "RouterCreateLabel": "Create"
    },
    "hi": {
        "RouterTitle": "Create Router",
        "RouterDescription": "Create a Router.",
        "RouterDescriptionField": "Description",
        "RouterName": "नाम",
        "FieldValidationErrorGeneric": "Validation error",
        "RouterCreateLabel": "Create"
    },
    "ja": {
        "RouterTitle": "Create Router",
        "RouterDescription": "Create a Router.",
        "RouterDescriptionField": "Description",
        "RouterName": "名",
        "FieldValidationErrorGeneric": "Validation error",
        "RouterCreateLabel": "Create"
    },
    "zh": {
        "RouterTitle": "Create Router",
        "RouterDescription": "Create a Router.",
        "RouterDescriptionField": "Description",
        "RouterName": "姓名",
        "FieldValidationErrorGeneric": "Validation error",
        "RouterCreateLabel": "Create"
    }
},

"form": {
    "description": "{{{i18n.RouterDescription}}}",

    "required_label": "{{{i18n.Required}}}",
    "required_fields": [
    {"id": "router_name", "type": "text", "placeholder": "{{{i18n.RouterName}}}", "required": true, 
        "pattern":"[0-9a-zA-Z]+", "validation_error": "{{{i18n.FieldValidationErrorGeneric}}}"},
    {"id": "router_description", "type": "text", "placeholder": "{{{i18n.RouterDescriptionField}}}"},
    {"id": "cores", "type": "hidden", "value": "1"},
    {"id": "memory", "type": "hidden", "value": "512"},
    {"id": "disk", "type": "hidden", "value": "30"},
    {"id": "adminid", "type": "hidden", "value": "routeradm"},
    {"id": "adminpass", "type": "hidden", "value": "$AUTO_GENERATE$"},
    {"id": "vmtype", "type": "hidden", "value": "router"},
    {"id": "creation_image_name", "type": "hidden", "value": "ubuntu_24_04_amd64"},
    {"id": "router_settings", "type": "hidden", "value":"[]"},
    {"id": "routerVnetsComponent", "inputtype": "router-vnets",
        "style":"body{background-color: #4C4C4C; color: #DCDCDC} select option{background-color: #4c4c4cc9; color: #DCDCDC} input::placeholder{color: #DCDCDC} span.roundbutton{border: 1px solid #DCDCDC}"}
    ],

    "submitlabel": "{{{i18n.RouterCreateLabel}}}",

    "submit_javascript": [
        "const form = arguments[1], shadowroot = form._form_shadowroot;",
        "const retObject = arguments[0]||{};",
        "const cloudinitTemplate = \"{system_info: {default_user: {name: \\u{007B}\\u{007B}\\u{007B}adminid\\u{007D}\\u{007D}\\u{007D}, home: /home/\\u{007B}\\u{007B}\\u{007B}adminid\\u{007D}\\u{007D}\\u{007D}, sudo: 'ALL=(ALL) NOPASSWD:ALL'}}, password: \\u{007B}\\u{007B}\\u{007B}adminpass\\u{007D}\\u{007D}\\u{007D}, chpasswd: {expire: false}, hostname: \\u{007B}\\u{007B}\\u{007B}router_name\\u{007D}\\u{007D}\\u{007D}, ssh_pwauth: true, package_upgrade: true, packages: [net-tools, qemu-guest-agent], runcmd: [[bash, -lc, 'systemctl start qemu-guest-agent'], [bash, -lc, 'echo net.ipv4.ip_forward = 1 >> /etc/sysctl.d/99-ip-forward.conf'], [bash, -lc, 'sysctl --system']]}\";",
        "const router = (await import(\"/framework/js/router.mjs\")).router;",
        "const mustache = await router.getMustache();",
        "const cloudInit = mustache.render(cloudinitTemplate, retObject);",
        "retObject.cloudinit_data = cloudInit;",
        "retObject.router_settings = JSON.stringify(shadowroot.querySelector('router-vnets').value);",
        "return true;"
    ],
    
    "load_javascript": [
        "const form = arguments[0] || {};",
        "const vnets = await $$.libapimanager.rest(APP_CONSTANTS.API_KLOUDUSTCMD, 'POST', {",
        "cmd: `listVnets`, ", "project: $$.libsession.get(APP_CONSTANTS.ACTIVE_PROJECT)}, true);",
        "form.required_fields[10].value = JSON.stringify(vnets.resources.map(v=>v.raw_name).filter(v=>!v.includes('backbone')));",
        "return form;"
    ]
}

}
